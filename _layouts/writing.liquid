---
layout: default
---
<div class="writing-page">
  <header class="writing-header">
    <h1 class="writing-title">{{ page.title | capitalize }}</h1>
    {% if page.description %}
      <p class="writing-tagline">{{ page.description }}</p>
    {% endif %}
    {% if page.intro %}
      <p class="writing-intro">{{ page.intro }}</p>
    {% endif %}
  </header>

  <div class="writing-list">
    {% assign all_posts = site.posts | sort: "date" | reverse %}
    {% for post in all_posts %}
    <article class="writing-item">
      <h3 class="writing-item__title">
        {% if post.external_url %}
          <a href="{{ post.external_url }}" target="_blank" rel="noopener noreferrer">{{ post.title }}<span class="writing-item__ext">↗</span></a>
        {% else %}
          <a href="{{ post.url | prepend: site.baseurl }}">{{ post.title }}</a>
        {% endif %}
      </h3>
      {% if post.description %}
        <p class="writing-item__desc">{{ post.description }}</p>
      {% else %}
        <p class="writing-item__desc">{{ post.content | strip_html | truncatewords: 30 }}</p>
      {% endif %}
      <div class="writing-item__meta">
        <time class="writing-item__date" datetime="{{ post.date | date_to_xmlschema }}">{{ post.date | date: "%B %d, %Y" }}</time>
        <div class="writing-item__tags">
          {% for tag in post.tags %}
            <span class="writing-item__tag">{{ tag }}</span>
          {% endfor %}
        </div>
      </div>
    </article>
    {% endfor %}
  </div>
</div>
