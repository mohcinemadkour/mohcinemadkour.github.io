---
layout: default
---
<div class="writing-page">
  <header class="writing-header">
    <h1 class="writing-title">{{ page.title | capitalize }}</h1>
    {% if page.description %}
      <p class="writing-tagline">{{ page.description }}</p>
    {% endif %}
    {% if page.intro %}
      <p class="writing-intro">{{ page.intro }}</p>
    {% endif %}
  </header>

  <div class="writing-grid">
    {% assign all_posts = site.posts | sort: 'date' | reverse %}
    {% for post in all_posts %}
      <article class="writing-card">
        <div class="writing-card__body">
          <h3 class="writing-card__title">
            {% if post.external_url %}
              <a href="{{ post.external_url }}" target="_blank" rel="noopener noreferrer">
                {{ post.title -}}
                <span class="writing-card__ext">↗</span>
              </a>
            {% else %}
              <a href="{{ post.url | prepend: site.baseurl }}">{{ post.title }}</a>
            {% endif %}
          </h3>
          <p class="writing-card__desc">
            {% if post.description %}
              {{ post.description | truncatewords: 28 }}
            {% else %}
              {{ post.content | strip_html | truncatewords: 28 }}
            {% endif %}
          </p>
        </div>
        <div class="writing-card__meta">
          <time class="writing-card__date" datetime="{{ post.date | date_to_xmlschema }}">
            {{ post.date | date: '%B %d, %Y' }}
          </time>
          <div class="writing-card__tags">
            {% for tag in post.tags limit: 3 %}
              <span class="writing-card__tag" data-tag="{{ tag }}">{{ tag }}</span>
            {% endfor %}
          </div>
        </div>
      </article>
    {% endfor %}
  </div>
</div>
