---
layout: default
---
{% assign year = page.date | date: '%Y' %}
{% assign tags = page.tags | join: '' %}
{% assign categories = page.categories | join: '' %}

{% if page._styles %}
  <style type="text/css">{{ page._styles }}</style>
{% endif %}

<div class="article-page">
  <!-- ── Header ─────────────────────────────────────────────────────── -->
  <header class="article-header">
    <h1 class="article-title">{{ page.title }}</h1>

    <div class="article-meta">
      <time class="article-date" datetime="{{ page.date | date_to_xmlschema }}">
        Created on {{ page.date | date: '%B %d, %Y' }}
      </time>

      {% if tags != '' or categories != '' %}
        <div class="article-tags">
          {% for tag in page.tags %}
            <span class="article-tag">{{ tag }}</span>
          {% endfor %}
          {% for category in page.categories %}
            <span class="article-tag article-tag--category">{{ category }}</span>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    {% if page.description %}
      <p class="article-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <!-- ── Body ──────────────────────────────────────────────────────── -->
  <article class="article-body">
    {% if page.toc and page.toc.beginning %}
      <div id="table-of-contents" class="article-toc">
        {% toc %}
      </div>
      <hr class="article-divider">
    {% endif %}
    <div id="markdown-content">
      {{ content }}
    </div>
  </article>

  <!-- ── Footer extras ─────────────────────────────────────────────── -->
  {% if page.citation %}
    {% include citation.liquid %}
  {% endif %}

  {% if page.related_publications %}
    <h2 class="article-refs-heading">References</h2>
    <div class="publications">
      {% bibliography --group_by none --cited_in_order %}
    </div>
  {% endif %}

  {% if site.related_blog_posts and site.related_blog_posts.enabled %}
    {% if page.related_posts == null or page.related_posts %}
      {% include related_posts.liquid %}
    {% endif %}
  {% endif %}

  {% if site.disqus_shortname and page.disqus_comments %}
    {% include disqus.liquid %}
  {% endif %}
  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>
